# ============================================================
# .env — Blog Backend Environment Variables
# UPDATED: Added all missing variables
# Copy this to .env and fill in your real values
# ============================================================

# ── Core Django ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-50-chars-min
JWT_SECRET_KEY=another-separate-long-random-string-for-jwt
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────
DB_NAME=blog_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_SESSION_URL=redis://127.0.0.1:6379/1

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email (console in dev, sendgrid/mailgun in prod) ─────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=hello@yourblog.com
ADMIN_EMAIL=you@youremail.com
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# MAILGUN_API_KEY=key-xxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com

# ── Cloudinary (optional — set USE_CLOUDINARY=True to enable) ─
USE_CLOUDINARY=False
CLOUD_NAME=your_cloud_name
API_KEY=your_api_key
API_SECRET=your_api_secret

# ── SEO ───────────────────────────────────────────────────────
SITE_NAME=YourBlog
SEO_DEFAULT_TITLE=Backend Engineering Blog — Django, System Design, AI/ML
SEO_DEFAULT_DESC=In-depth tutorials on System Design, DSA, Django, AI/ML, Python, and GenAI.
TWITTER_HANDLE=@yourhandle

# ── Production only (leave blank in dev) ─────────────────────
# SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/XXXX
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── AdSense (Phase 3) ─────────────────────────────────────────
# Add your real publisher ID after AdSense approval
ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
