# ═══════════════════════════════════════════════════════════════
# blog-shaha Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Django Core ───────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
JWT_SECRET_KEY=your-jwt-secret-key-here
DJANGO_ENV=development
# DJANGO_ENV=production

# ── Database ──────────────────────────────────────────────────
# For development with PostgreSQL (NeonDB, Supabase, local, etc.)
USE_POSTGRES=False
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_URL=redis://localhost:6379/1

# ── Allowed Hosts (production) ────────────────────────────────
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── CORS (frontend URL) ──────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── Email ─────────────────────────────────────────────────────
# Console backend for development (prints emails to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use SendGrid or Mailgun:
# EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
DEFAULT_FROM_EMAIL=hello@yourblog.com
ADMIN_EMAIL=admin@yourblog.com

# ── Cloudinary (optional — for cloud image storage) ───────────
USE_CLOUDINARY=False
CLOUD_NAME=your-cloud-name
API_KEY=your-api-key
API_SECRET=your-api-secret

# ── SEO ───────────────────────────────────────────────────────
SITE_NAME=YourBlog
SEO_DEFAULT_TITLE=Backend Engineering Blog
SEO_DEFAULT_DESC=In-depth tutorials on System Design, DSA, Django, AI/ML, and Python.
TWITTER_HANDLE=@yourhandle

# ── Error Tracking (optional) ────────────────────────────────
SENTRY_DSN=
